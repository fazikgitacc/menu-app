# /etc/systemd/system/menu-app.service
# sudo systemctl daemon-reload && sudo systemctl enable --now menu-app

[Unit]
Description=Menu App (FastAPI/Uvicorn)
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/var/www/menu-app/backend
Environment="PATH=/var/www/menu-app/backend/.venv/bin"
ExecStart=/var/www/menu-app/backend/.venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
