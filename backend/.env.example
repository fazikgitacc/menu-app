# ===== Обязательно поменять в продакшене =====
# Длинный случайный ключ для подписи JWT. Сгенерировать:  openssl rand -hex 32
SECRET_KEY=change-me-to-a-long-random-string

# Токен Hugging Face (https://huggingface.co/settings/tokens), нужен для генерации картинок
HF_API_TOKEN=

# ===== Hugging Face (опционально) =====
# Модель text-to-image
HF_MODEL=stabilityai/stable-diffusion-xl-base-1.0
# Полный URL инференса (оставьте пустым — соберётся из HF_MODEL).
# При необходимости можно указать роутер провайдеров, напр.:
# HF_API_URL=https://router.huggingface.co/hf-inference/models/stabilityai/stable-diffusion-xl-base-1.0
HF_API_URL=

# ===== Cookie / сессии =====
# В продакшене под HTTPS обязательно true
COOKIE_SECURE=false
COOKIE_NAME=access_token
ACCESS_TOKEN_EXPIRE_DAYS=30

# ===== Прочее =====
# DATABASE_URL=sqlite:///./menu.db
# FRONTEND_DIR=/abs/path/to/frontend
MAX_IMAGE_MB=10
