# ===== Обязательно поменять в продакшене =====
# Длинный случайный ключ для подписи JWT. Сгенерировать:  openssl rand -hex 32
SECRET_KEY=change-me-to-a-long-random-string

# ===== Генерация картинок: Pollinations.ai (бесплатно, без ключа) =====
# Базовый URL генерации (по умолчанию рабочий, менять не нужно):
# POLLINATIONS_BASE=https://image.pollinations.ai/prompt
# Модель / размер картинки:
# IMAGE_MODEL=flux
# IMAGE_WIDTH=768
# IMAGE_HEIGHT=768
# IMAGE_TIMEOUT=150
# Необязательный ключ Pollinations (pk_/sk_) для повышенных лимитов — для базовой работы НЕ нужен:
# POLLINATIONS_TOKEN=

# ===== Cookie / сессии =====
# В продакшене под HTTPS обязательно true
COOKIE_SECURE=false
COOKIE_NAME=access_token
ACCESS_TOKEN_EXPIRE_DAYS=30

# ===== Прочее =====
# DATABASE_URL=sqlite:///./menu.db
# FRONTEND_DIR=/abs/path/to/frontend
MAX_IMAGE_MB=10
